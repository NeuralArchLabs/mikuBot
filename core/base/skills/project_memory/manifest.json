{
    "name": "project_memory",
    "description": "Guarda y carga información persistente del proyecto. Útil para mantener contexto entre ejecuciones del agente.",
    "parameters": {
        "type": "object",
        "properties": {
            "action": {
                "type": "string",
                "description": "Acción a realizar: 'save' (guardar), 'load' (cargar), 'list' (listar historias), 'delete' (borrar)"
            },
            "key": {
                "type": "string",
                "description": "Identificador único para la memoria (ej: 'build_status', 'dependencies')"
            },
            "content": {
                "type": "string",
                "description": "Contenido a guardar (para la acción 'save')"
            },
            "path": {
                "type": "string",
                "description": "Ruta del proyecto (por defecto: ./)",
                "default": "./"
            }
        },
        "required": ["action"]
    },
    "runtime": "python",
    "entry": "main.py"
}