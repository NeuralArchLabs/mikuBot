{
    "name": "read_file",
    "description": "Lee el contenido completo de un archivo. Soporta archivos de texto, código, JSON, YAML, etc.",
    "parameters": {
        "type": "object",
        "properties": {
            "path": {
                "type": "string",
                "description": "Ruta relativa o absoluta del archivo a leer. Puede usar ./ para rutas relativas."
            },
            "encoding": {
                "type": "string",
                "description": "Codificación del archivo (utf-8, latin-1, etc.)",
                "default": "utf-8"
            },
            "start_line": {
                "type": "integer",
                "description": "Línea inicial a leer (1-indexed, opcional)"
            },
            "end_line": {
                "type": "integer",
                "description": "Línea final a leer (1-indexed, opcional)"
            }
        },
        "required": ["path"]
    },
    "runtime": "python",
    "entry": "main.py"
}