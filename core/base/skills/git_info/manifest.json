{
    "name": "git_info",
    "description": "Obtiene información del repositorio Git: ramas, commits, estado del repositorio, etc.",
    "parameters": {
        "type": "object",
        "properties": {
            "path": {
                "type": "string",
                "description": "Ruta del repositorio Git",
                "default": "./"
            },
            "info_type": {
                "type": "string",
                "description": "Tipo de información: 'status', 'branches', 'commits', 'all'",
                "default": "all"
            }
        }
    },
    "runtime": "python",
    "entry": "main.py"
}